      "content": "<style>\n  .lp-con .section{padding:64px 0}\n  .lp-con .muted{color:var(--muted)}\n  .lp-con .badge-lp{display:inline-flex;gap:8px;align-items:center;background:linear-gradient(90deg,var(--accent),var(--brand-2));color:#fff;padding:6px 14px;border-radius:999px;font-size:12px;font-weight:600}\n  .lp-con .btn-lp{display:inline-block;background:var(--accent);color:#fff;padding:16px 32px;border-radius:12px;font-weight:700;font-size:16px;box-shadow:var(--shadow);transition:transform .05s ease;text-decoration:none}\n  .lp-con .btn-lp:hover{transform:translateY(-2px);text-decoration:none}\n  .lp-con .btn-outline{background:transparent;color:var(--accent);border:2px solid var(--accent)}\n  .lp-con .grid-lp{display:grid;gap:24px}\n  .lp-con .grid-lp-2{grid-template-columns:1fr 1fr}\n  .lp-con .grid-lp-3{grid-template-columns:1fr 1fr 1fr}\n  .lp-con .card-lp{background:var(--surface);padding:28px;border:1px solid var(--line);border-radius:18px;box-shadow:var(--shadow)}\n  .lp-con .icon-box-lp{width:52px;height:52px;border-radius:14px;background:linear-gradient(135deg,var(--accent),var(--brand-2));display:grid;place-items:center;color:#fff;font-size:20px;font-weight:700;margin-bottom:16px}\n  .lp-con .stat-num-lp{font-size:40px;font-weight:800;background:linear-gradient(135deg,var(--accent),var(--brand-2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}\n  .lp-con .stat-num-sm{font-size:32px;font-weight:800;background:linear-gradient(135deg,var(--accent),var(--brand-2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}\n  .lp-con .note-lp{font-size:13px;color:var(--muted)}\n  .lp-con .spec-table{width:100%;border-collapse:collapse;margin-top:16px}\n  .lp-con .spec-table td,.lp-con .spec-table th{padding:12px 16px;text-align:left;border-bottom:1px solid var(--line)}\n  .lp-con .spec-table th{background:var(--surface);font-weight:600;width:35%;color:var(--muted);font-size:14px}\n  .lp-con .step-num-lp{width:36px;height:36px;border-radius:50%;background:var(--accent);color:#fff;display:grid;place-items:center;font-weight:700;font-size:14px;flex-shrink:0}\n  .lp-con .divider-lp{height:1px;background:var(--line);margin:0}\n  @media(max-width:768px){\n    .lp-con .grid-lp-2{grid-template-columns:1fr}\n    .lp-con .grid-lp-3{grid-template-columns:1fr}\n  }\n</style>\n\n<div class=\"lp-con\">\n\n<script type=\"application/ld+json\">\n{\n  \"@context\": \"https://schema.org\",\n  \"@type\": \"Service\",\n  \"name\": \"建設コンサルタント向けドローン測量サービス\",\n  \"provider\": {\n    \"@type\": \"Organization\",\n    \"name\": \"東海エアサービス株式会社\",\n    \"url\": \"https://www.tokaiair.com/\"\n  },\n  \"areaServed\": [\"愛知県\", \"岐阜県\", \"三重県\"],\n  \"description\": \"i-Construction対応の高精度ドローン測量。公共測量基準準拠、点群処理からBIM/CIM連携までワンストップ対応。\"\n}\n</script>\n\n<!-- Hero -->\n<section class=\"section\" style=\"background:radial-gradient(1200px 600px at 50% -200px, rgba(16,185,129,.12), transparent);padding:80px 0 64px\">\n  <div class=\"container\" style=\"text-align:center\">\n    <span class=\"badge-lp\">For Consultants</span>\n    <h1 style=\"margin:20px 0 12px;font-size:36px;line-height:1.3\">\n      i-Construction対応の<br><span style=\"color:var(--accent)\">高精度ドローン測量</span>\n    </h1>\n    <p class=\"muted\" style=\"max-width:640px;margin:0 auto 28px;font-size:17px\">\n      建設コンサルタント様の外注パートナーとして。<br>公共測量基準準拠のドローン測量から点群処理・BIM/CIM連携まで、ワンストップでお任せください。\n    </p>\n    <div style=\"display:flex;gap:12px;justify-content:center;flex-wrap:wrap\">\n      <a href=\"/contact/\" class=\"btn-lp\">費用について問い合わせる</a>\n      <a href=\"/uav-survey/\" class=\"btn-lp btn-outline\">サービス詳細</a>\n    </div>\n    <p class=\"note-lp\" style=\"margin-top:12px\">お電話でのご相談: <a href=\"tel:05036277871\">050-3627-7871</a>（平日 9:00-17:00）</p>\n  </div>\n</section>\n\n<hr class=\"divider-lp\">\n\n<!-- 課題提起 -->\n<section class=\"section\">\n  <div class=\"container\">\n    <div style=\"text-align:center;margin-bottom:40px\">\n      <span class=\"badge-lp\">Pain Points</span>\n      <h2 style=\"margin:12px 0 8px\">こんな課題をお持ちではありませんか？</h2>\n    </div>\n    <div class=\"grid-lp grid-lp-3\">\n      <div class=\"card-lp\">\n        <div class=\"icon-box-lp\" role=\"img\" aria-label=\"精度\">Q</div>\n        <h3 style=\"margin:0 0 8px\">公共測量の精度要件</h3>\n        <p class=\"muted\" style=\"margin:0\">i-Construction基準の精度を満たす測量データが求められるが、自社にドローン測量のノウハウがない。</p>\n      </div>\n      <div class=\"card-lp\">\n        <div class=\"icon-box-lp\" role=\"img\" aria-label=\"リソース\">R</div>\n        <h3 style=\"margin:0 0 8px\">点群処理のリソース不足</h3>\n        <p class=\"muted\" style=\"margin:0\">ドローンで撮影できても、点群データの処理・解析に専門人材と高スペックPCが必要。外注先を探している。</p>\n      </div>\n      <div class=\"card-lp\">\n        <div class=\"icon-box-lp\" role=\"img\" aria-label=\"納期\">D</div>\n        <h3 style=\"margin:0 0 8px\">短納期・広域への対応</h3>\n        <p class=\"muted\" style=\"margin:0\">複数現場を短期間で測量する必要があるが、自社リソースでは対応しきれない。信頼できる外注先が必要。</p>\n      </div>\n    </div>\n  </div>\n</section>\n\n<hr class=\"divider-lp\">\n\n<!-- 解決策 -->\n<section class=\"section\" style=\"background:var(--surface)\">\n  <div class=\"container\">\n    <div style=\"text-align:center;margin-bottom:40px\">\n      <span class=\"badge-lp\">Solution</span>\n      <h2 style=\"margin:12px 0 8px\">測量から点群処理までワンストップ</h2>\n      <p class=\"muted\">御社の測量外注パートナーとして、高精度データを安定供給します。</p>\n    </div>\n    <div class=\"grid-lp grid-lp-2\">\n      <div class=\"card-lp\">\n        <h3 style=\"margin:0 0 12px;color:var(--accent)\">公共測量基準準拠</h3>\n        <p class=\"muted\" style=\"margin:0\">国土交通省「UAVを用いた公共測量マニュアル」に準拠した作業手順。標定点設置からデータ検証まで、精度管理を徹底します。</p>\n      </div>\n      <div class=\"card-lp\">\n        <h3 style=\"margin:0 0 12px;color:var(--accent)\">点群処理・3Dモデル生成</h3>\n        <p class=\"muted\" style=\"margin:0\">SfM処理による高密度点群データの生成、フィルタリング、メッシュ化まで対応。LAS/LAZ形式で納品します。</p>\n      </div>\n      <div class=\"card-lp\">\n        <h3 style=\"margin:0 0 12px;color:var(--accent)\">BIM/CIM連携</h3>\n        <p class=\"muted\" style=\"margin:0\">3Dモデルデータを各種BIM/CIMソフトウェアに対応した形式で出力。設計・施工管理とのシームレスな連携を実現します。</p>\n      </div>\n      <div class=\"card-lp\">\n        <h3 style=\"margin:0 0 12px;color:var(--accent)\">柔軟な外注体制</h3>\n        <p class=\"muted\" style=\"margin:0\">御社の案件規模に合わせて対応。単発案件から年間契約まで、必要な時に必要なリソースを提供します。</p>\n      </div>\n    </div>\n  </div>\n</section>\n\n<hr class=\"divider-lp\">\n\n<!-- 技術仕様 -->\n<section class=\"section\">\n  <div class=\"container\">\n    <div style=\"text-align:center;margin-bottom:40px\">\n      <span class=\"badge-lp\">Technical Specs</span>\n      <h2 style=\"margin:12px 0 8px\">技術仕様</h2>\n    </div>\n    <div class=\"grid-lp grid-lp-2\">\n      <div class=\"card-lp\">\n        <h3 style=\"margin:0 0 4px\">測量精度</h3>\n        <table class=\"spec-table\">\n          <tr><th>水平精度</th><td>±5cm（対空標識使用時）</td></tr>\n          <tr><th>垂直精度</th><td>±5cm（対空標識使用時）</td></tr>\n          <tr><th>GSD</th><td>1〜3cm/pixel（飛行高度による）</td></tr>\n          <tr><th>基準</th><td>i-Construction基準準拠</td></tr>\n        </table>\n      </div>\n      <div class=\"card-lp\">\n        <h3 style=\"margin:0 0 4px\">対応範囲・納品物</h3>\n        <table class=\"spec-table\">\n          <tr><th>対応エリア</th><td>愛知・岐阜・三重（その他応相談）</td></tr>\n          <tr><th>点群データ</th><td>LAS / LAZ / CSV</td></tr>\n          <tr><th>オルソ画像</th><td>GeoTIFF</td></tr>\n          <tr><th>3Dモデル</th><td>OBJ / FBX / IFC（応相談）</td></tr>\n        </table>\n      </div>\n    </div>\n  </div>\n</section>\n\n<hr class=\"divider-lp\">\n\n<!-- 実績数値 -->\n<section class=\"section\" style=\"background:var(--surface)\">\n  <div class=\"container\">\n    <div style=\"text-align:center;margin-bottom:40px\">\n      <span class=\"badge-lp\">Track Record</span>\n      <h2 style=\"margin:12px 0 8px\">実績</h2>\n    </div>\n    <div class=\"grid-lp grid-lp-3\" style=\"text-align:center\">\n      <div class=\"card-lp\">\n        <div class=\"stat-num-lp\">7+</div>\n        <p style=\"margin:4px 0 0;font-weight:600\">コンサル向け測量実績</p>\n        <p class=\"note-lp\">河川・砂防・道路等の多分野</p>\n      </div>\n      <div class=\"card-lp\">\n        <div class=\"stat-num-lp\">±5cm</div>\n        <p style=\"margin:4px 0 0;font-weight:600\">測量精度</p>\n        <p class=\"note-lp\">i-Construction基準準拠</p>\n      </div>\n      <div class=\"card-lp\">\n        <div class=\"stat-num-lp\">60万円〜</div>\n        <p style=\"margin:4px 0 0;font-weight:600\">平均受注単価</p>\n        <p class=\"note-lp\">測量+点群処理込み</p>\n      </div>\n    </div>\n  </div>\n</section>\n\n<hr class=\"divider-lp\">\n\n<!-- 導入事例 -->\n<section class=\"section\">\n  <div class=\"container\">\n    <div style=\"text-align:center;margin-bottom:40px\">\n      <span class=\"badge-lp\">Case Study</span>\n      <h2 style=\"margin:12px 0 8px\">導入事例</h2>\n    </div>\n    <div class=\"grid-lp grid-lp-2\">\n      <div class=\"card-lp\" style=\"border-left:4px solid var(--accent)\">\n        <p class=\"note-lp\" style=\"margin:0 0 8px\">C社（建設コンサルタント・岐阜県）</p>\n        <h3 style=\"margin:0 0 12px\">河川・砂防施設の広域測量</h3>\n        <p class=\"muted\" style=\"margin:0 0 12px\">中津川市周辺の複数の河川・砂防施設において、ドローンによる地形測量を実施。従来の地上測量と比較して、現地作業日数を大幅に短縮。点群データから横断図・縦断図を自動生成し、設計業務の効率化に貢献しました。</p>\n        <div style=\"display:flex;gap:24px;flex-wrap:wrap\">\n          <div><span class=\"note-lp\">対象</span><br><strong>河川4箇所</strong></div>\n          <div><span class=\"note-lp\">サービス</span><br><strong>測量+点群処理</strong></div>\n          <div><span class=\"note-lp\">納品物</span><br><strong>点群+横断図</strong></div>\n        </div>\n      </div>\n      <div class=\"card-lp\" style=\"border-left:4px solid var(--brand-2)\">\n        <p class=\"note-lp\" style=\"margin:0 0 8px\">D社（建設コンサルタント・愛知県）</p>\n        <h3 style=\"margin:0 0 12px\">公共測量案件の外注パートナー</h3>\n        <p class=\"muted\" style=\"margin:0 0 12px\">公共測量基準に準拠したドローン測量を継続的に外注いただいています。標定点の設置から点群処理、精度検証レポートの作成まで一括対応。御社の品質管理基準に合わせたデータ納品を行っています。</p>\n        <div style=\"display:flex;gap:24px;flex-wrap:wrap\">\n          <div><span class=\"note-lp\">契約形態</span><br><strong>年間契約</strong></div>\n          <div><span class=\"note-lp\">精度</span><br><strong>±5cm以内</strong></div>\n          <div><span class=\"note-lp\">評価</span><br><strong>継続利用中</strong></div>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n<hr class=\"divider-lp\">\n\n<!-- 料金目安 -->\n<section class=\"section\" style=\"background:var(--surface)\">\n  <div class=\"container\">\n    <div style=\"text-align:center;margin-bottom:40px\">\n      <span class=\"badge-lp\">Pricing</span>\n      <h2 style=\"margin:12px 0 8px\">料金目安</h2>\n    </div>\n    <div class=\"grid-lp grid-lp-3\">\n      <div class=\"card-lp\" style=\"text-align:center\">\n        <p class=\"note-lp\" style=\"margin:0 0 8px\">ドローン測量のみ</p>\n        <div class=\"stat-num-sm\">18万円〜</div>\n        <p style=\"margin:8px 0 0;font-weight:600\">撮影+標定点設置</p>\n        <p class=\"note-lp\" style=\"margin:8px 0 0\">対象面積1ha程度の場合<br>標定点4〜6点含む</p>\n      </div>\n      <div class=\"card-lp\" style=\"text-align:center;border:2px solid var(--accent)\">\n        <p style=\"margin:0 0 8px;color:var(--accent);font-weight:700;font-size:13px\">おすすめ</p>\n        <div class=\"stat-num-sm\">35万円〜</div>\n        <p style=\"margin:8px 0 0;font-weight:600\">測量+点群処理セット</p>\n        <p class=\"note-lp\" style=\"margin:8px 0 0\">撮影+SfM処理+点群納品<br>オルソ画像・DSM含む</p>\n      </div>\n      <div class=\"card-lp\" style=\"text-align:center\">\n        <p class=\"note-lp\" style=\"margin:0 0 8px\">フルパッケージ</p>\n        <div class=\"stat-num-sm\">60万円〜</div>\n        <p style=\"margin:8px 0 0;font-weight:600\">測量+点群+図面出力</p>\n        <p class=\"note-lp\" style=\"margin:8px 0 0\">横断図・縦断図・土量計算<br>BIM/CIM用データ出力含む</p>\n      </div>\n    </div>\n    <p class=\"note-lp\" style=\"text-align:center;margin-top:20px\">※ 面積・現場条件・要求精度により変動します。正確なお見積りはお問い合わせください。</p>\n  </div>\n</section>\n\n<hr class=\"divider-lp\">\n\n<!-- ご利用の流れ -->\n<section class=\"section\">\n  <div class=\"container\">\n    <div style=\"text-align:center;margin-bottom:40px\">\n      <span class=\"badge-lp\">Flow</span>\n      <h2 style=\"margin:12px 0 8px\">ご利用の流れ</h2>\n    </div>\n    <div style=\"max-width:600px;margin:0 auto;display:flex;flex-direction:column;gap:24px\">\n      <div style=\"display:flex;gap:16px;align-items:flex-start\">\n        <div class=\"step-num-lp\">1</div>\n        <div>\n          <h4 style=\"margin:0 0 4px\">お問い合わせ・ヒアリング</h4>\n          <p class=\"muted\" style=\"margin:0\">対象現場の概要・要求精度・納品形式をお聞かせください。</p>\n        </div>\n      </div>\n      <div style=\"display:flex;gap:16px;align-items:flex-start\">\n        <div class=\"step-num-lp\">2</div>\n        <div>\n          <h4 style=\"margin:0 0 4px\">お見積り・測量計画</h4>\n          <p class=\"muted\" style=\"margin:0\">現場条件に基づき、飛行計画・標定点配置計画・お見積りをご提示します。</p>\n        </div>\n      </div>\n      <div style=\"display:flex;gap:16px;align-items:flex-start\">\n        <div class=\"step-num-lp\">3</div>\n        <div>\n          <h4 style=\"margin:0 0 4px\">現地測量</h4>\n          <p class=\"muted\" style=\"margin:0\">標定点設置・ドローン飛行・検証点測量を実施します。</p>\n        </div>\n      </div>\n      <div style=\"display:flex;gap:16px;align-items:flex-start\">\n        <div class=\"step-num-lp\">4</div>\n        <div>\n          <h4 style=\"margin:0 0 4px\">データ処理・品質検証</h4>\n          <p class=\"muted\" style=\"margin:0\">SfM処理・点群生成・精度検証を行い、品質レポートとともに納品します。</p>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n<hr class=\"divider-lp\">\n\n<!-- CTA -->\n<section class=\"section\" style=\"background:radial-gradient(800px 400px at 50% 100%, rgba(16,185,129,.1), transparent)\">\n  <div class=\"container\" style=\"text-align:center\">\n    <h2 style=\"margin:0 0 12px\">測量の外注先をお探しですか？</h2>\n    <p class=\"muted\" style=\"max-width:520px;margin:0 auto 28px\">案件の概要をお聞かせいただければ、精度要件に応じた最適なプランをご提案します。お見積りは無料です。</p>\n    <a href=\"/contact/\" class=\"btn-lp\" style=\"font-size:18px;padding:18px 40px\">費用について問い合わせる</a>\n    <p class=\"note-lp\" style=\"margin-top:12px\">お電話: <a href=\"tel:05036277871\">050-3627-7871</a>（平日 9:00-17:00）</p>\n    <p class=\"note-lp\">通常1営業日以内にご返信いたします</p>\n  </div>\n</section>\n\n</div>\n<script type=\"application/ld+json\">\n{\n  \"@context\": \"https://schema.org\",\n  \"@type\": \"FAQPage\",\n  \"mainEntity\": [\n    {\n      \"@type\": \"Question\",\n      \"name\": \"ドローン測量の精度はどの程度ですか？\",\n      \"acceptedAnswer\": {\n        \"@type\": \"Answer\",\n        \"text\": \"GCP（地上基準点）設置により水平精度±2cm、垂直精度±5cm以内の高精度測量が可能です。i-Construction出来形管理基準にも適合します。\"\n      }\n    },\n    {\n      \"@type\": \"Question\",\n      \"name\": \"納品までの期間はどのくらいですか？\",\n      \"acceptedAnswer\": {\n        \"@type\": \"Answer\",\n        \"text\": \"現場撮影後、通常3〜5営業日で点群データ・オルソ画像を納品します。緊急対応も可能ですのでご相談ください。\"\n      }\n    },\n    {\n      \"@type\": \"Question\",\n      \"name\": \"対応エリアはどこですか？\",\n      \"acceptedAnswer\": {\n        \"@type\": \"Answer\",\n        \"text\": \"愛知県・岐阜県・三重県・静岡県を中心に、名古屋から車で2時間圏内のエリアに対応しています。遠方の場合もご相談ください。\"\n      }\n    }\n  ]\n}\n</script>"
    }
  }
}